# ── Base de datos ─────────────────────────────────────────────────────────────
# Formato: mysql+pymysql://usuario:contrasena@host:puerto/nombre_bd
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/agromatina_web

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-seguro
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Correo electronico ────────────────────────────────────────────────────────
# EMAIL_MODE=console  -> imprime correos en consola (desarrollo, no necesita SMTP)
# EMAIL_MODE=smtp     -> envia correos reales via SMTP
EMAIL_MODE=console

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Para Gmail: usa una "Contrasena de aplicacion" (no la contrasena normal)
# Activa 2FA en tu cuenta Google y genera una en: myaccount.google.com/apppasswords
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=noreply@agromatina.com

# ── Tokens transitorios ───────────────────────────────────────────────────────
VERIFICATION_TOKEN_HOURS=24
RECOVERY_TOKEN_MINUTES=30

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL base del frontend — usada para armar los links en los correos
FRONTEND_URL=http://localhost:5173

# ── Almacenamiento de archivos (cotizaciones RF-31, comprobantes RF-25) ───────
# STORAGE_MODE=cloudinary  -> sube archivos a Cloudinary (produccion/integracion)
# STORAGE_MODE=local       -> guarda en disco (carpeta media/), sin cuenta cloud
STORAGE_MODE=cloudinary
# Credenciales del panel de Cloudinary (Settings -> API Keys)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
# Solo si STORAGE_MODE=local
LOCAL_STORAGE_DIR=media
LOCAL_STORAGE_BASE_URL=http://localhost:8000/media

# ── Notificacion por WhatsApp (cotizaciones RF-32) ────────────────────────────
# WHATSAPP_MODE=console -> imprime el mensaje en consola (desarrollo)
# WHATSAPP_MODE=api     -> envia via WhatsApp Cloud API de Meta
WHATSAPP_MODE=console
WHATSAPP_DESTINO=50688887777
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_ACCESS_TOKEN=tu_access_token

# ── Sincronizacion de catalogo (proceso P4) ───────────────────────────────────
# API key que presenta la app de escritorio de Jakob en el header X-API-Key para
# cargar/actualizar productos. Genera con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SYNC_API_KEY=cambia-esta-api-key-de-sync-en-produccion

# ── Desarrollo ────────────────────────────────────────────────────────────────
DEBUG=false
